{
  "name": "codex-proxy",
  "version": "1.0.4",
  "description": "Reverse proxy that exposes Codex Desktop Responses API as OpenAI-compatible /v1/chat/completions",
  "author": "codex-proxy",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx watch src/index.ts",
    "dev:web": "cd web && npx vite",
    "dev:desktop": "cd desktop && npx vite",
    "build:web": "cd web && npx vite build",
    "build:desktop": "cd desktop && npx vite build",
    "build": "npm run build:web && npm run build:desktop && tsc",
    "start": "node dist/index.js",
    "check-update": "tsx scripts/check-update.ts",
    "check-update:watch": "tsx scripts/check-update.ts --watch",
    "extract": "tsx scripts/extract-fingerprint.ts",
    "apply-update": "tsx scripts/apply-update.ts",
    "apply-update:dry": "tsx scripts/apply-update.ts --dry-run",
    "setup": "tsx scripts/setup-curl.ts",
    "update": "tsx scripts/full-update.ts",
    "postinstall": "tsx scripts/setup-curl.ts",
    "app:dev": "npm run build && node electron/build.mjs && electron .",
    "app:build": "npm run build && node electron/build.mjs",
    "app:pack": "npm run app:build && electron-builder --config electron-builder.yml",
    "app:pack:win": "npm run app:build && electron-builder --config electron-builder.yml --win",
    "app:pack:mac": "npm run app:build && electron-builder --config electron-builder.yml --mac",
    "app:pack:linux": "npm run app:build && electron-builder --config electron-builder.yml --linux"
  },
  "dependencies": {
    "@hono/node-server": "^1.0.0",
    "hono": "^4.0.0",
    "js-yaml": "^4.1.0",
    "undici": "^7.0.0",
    "zod": "^3.23.0"
  },
  "optionalDependencies": {
    "koffi": "^2.15.1"
  },
  "devDependencies": {
    "@electron/asar": "^3.2.0",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^22.0.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.0.0",
    "electron-to-chromium": "^1.5.302",
    "esbuild": "^0.25.12",
    "js-beautify": "^1.15.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.4"
  }
}
